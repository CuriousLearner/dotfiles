# Ghostty configuration.
#
# Font is set to MesloLGS NF (the Powerlevel10k / Nerd Font) so the prompt's
# powerline separators, icons, and emoji render correctly. Without this,
# Ghostty's default font lacks those glyphs and p10k shows tofu boxes.
font-family = MesloLGS NF
font-size = 14

# Keep the window chrome minimal.
macos-titlebar-style = tabs

# Shell integration: new tabs/splits inherit the current directory (OSC 7),
# prompt marks for jump-to-prompt, and sudo support. Auto-detects zsh.
shell-integration = detect

# Translucent, blurred window. background-opacity < 1 is what makes the blur
# visible; alpha-blending keeps text crisp over the translucent background.
background-opacity = 0.92
background-blur-radius = 20
alpha-blending = linear-corrected
