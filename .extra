
# CuriousLearner signature on interactive shell start.
# The banner is 62 columns wide, so it only renders when the terminal is at
# least that wide; narrower terminals (and split panes) get a compact one-liner.
_cl_cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
if [ "$_cl_cols" -ge 62 ]; then
  cat <<'CLSIG'
  _____         _               __
 / ___/_ ______(_)__  __ _____ / /  ___ ___ ________  ___ ____
/ /__/ // / __/ / _ \/ // (_-</ /__/ -_) _ `/ __/ _ \/ -_) __/
\___/\_,_/_/ /_/\___/\_,_/___/____/\__/\_,_/_/ /_//_/\__/_/
CLSIG
else
  printf '\033[36m❯ CuriousLearner\033[0m\n'
fi
unset _cl_cols
