#!/bin/bash
#
# JARVIS-style shell greeting: a time-aware salutation that addresses you by
# name and a dry quip, then an affirmation on the line below. Override the name
# with $JARVIS_NAME.
#

_jarvis() {
  # Name: $JARVIS_NAME, else the account's full name (macOS `id -F`), else a default.
  local name
  name="${JARVIS_NAME:-$(id -F 2>/dev/null | awk '{print $1}')}"
  name="${name:-Sanyam}"

  # Time-aware salutation. 10# forces base-10 so "08"/"09" aren't read as octal.
  local hour salutation
  hour=$(date +%H)
  if   (( 10#$hour >= 5  && 10#$hour < 12 )); then salutation="Good morning"
  elif (( 10#$hour >= 12 && 10#$hour < 17 )); then salutation="Good afternoon"
  elif (( 10#$hour >= 17 && 10#$hour < 22 )); then salutation="Good evening"
  else                                             salutation="Burning the midnight oil"
  fi

  # Dry, helpful, faintly sarcastic. Keep them one line.
  local quips=(
    "All systems nominal. Shall we begin?"
    "The terminal is yours. Do try not to rm -rf anything irreplaceable."
    "Ready when you are. I've kept the electrons warm."
    "Running at peak efficiency. The coffee machine, less so."
    "Environment prepared. Shall I compile something?"
    "Systems online. Let's make good decisions today."
    "At your service. Coffee, regrettably, not included."
    "Standing by. Your genius awaits."
    "Everything is under control. Mostly."
    "Welcome back. I trust the meeting was survivable."
    "Shell warmed, PATH swept, ego intact. Proceed."
    "I've flagged nothing on fire. A promising start."
  )
  # Earnest affirmations, kept alongside the dry quips so the message rotates
  # between wit and encouragement.
  local affirmations=(
    "Progress, not perfection."
    "One commit at a time."
    "Done is better than perfect."
    "You have solved hard problems before; you will solve this one too."
    "Small steps every day add up."
    "Curiosity is your superpower."
    "Keep learning, keep building."
    "Breathe. Then ship."
    "Your best work is still ahead of you."
    "Fix the root cause, not the symptom."
    "Write the code future-you will thank you for."
    "Calm mind, clean diff."
  )

  local quip="${quips[RANDOM % ${#quips[@]}]}"
  local affirmation="${affirmations[RANDOM % ${#affirmations[@]}]}"

  # Line 1: bold-cyan salutation + dim quip (the JARVIS voice).
  # Blank line, then the affirmation (dim, indented), then a trailing blank line.
  printf '\033[1;36m%s, %s.\033[0m \033[2m%s\033[0m\n\n' "$salutation" "$name" "$quip"
  printf '\033[2m  %s\033[0m\n\n' "$affirmation"
}

_jarvis "$@"
