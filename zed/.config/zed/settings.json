// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      // Reuse the already-authenticated Homebrew Claude Code CLI instead of the
      // adapter's un-authed vendored copy (registry auth is decoupled from the
      // system CLI). Absolute path required — Zed does not $PATH-resolve this,
      // so it's /opt/homebrew/bin on Apple Silicon; adjust on other machines.
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "/opt/homebrew/bin/claude"
      }
    }
  },
  "edit_predictions": {
    "ollama": {
      "model": "qwen2.5-coder:7b-base",
      "api_url": "http://localhost:11434"
    },
    "provider": "ollama"
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "base_keymap": "VSCode",
  "terminal": {
    "font_family": "MesloLGS NF",
    "font_fallbacks": ["Apple Color Emoji"]
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  }
}
